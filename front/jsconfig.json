{
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "css.lint.unknownAtRules": "ignore",
  "css.validate": true,
  "scss.validate": true,
  "tailwindCSS.includeLanguages": {
    "vue": "html"
  },
  "editor.quickSuggestions": {
    "strings": true
  }
}