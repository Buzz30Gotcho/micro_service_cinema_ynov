# ========================================
# CONFIGURATION MONGODB
# ========================================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=adminpass
MONGO_DB=users_db
MONGO_USER=admin
MONGO_PASSWORD=adminpass
MONGO_PORT=27017
MONGO_HOST=auth_bdd

# ========================================
# MONGO EXPRESS (Interface Web MongoDB)
# ========================================
MONGO_EXPRESS_PORT=8082
ME_CONFIG_MONGODB_ADMINUSERNAME=admin
ME_CONFIG_MONGODB_ADMINPASSWORD=adminpass
ME_CONFIG_MONGODB_SERVER=auth_bdd

# ========================================
# CLÉS DE SÉCURITÉ
# ========================================
# Ces clés seront générées automatiquement au premier lancement
# Ne les modifiez pas manuellement
SECRET_KEY=
ENCRYPTION_KEY=

# ========================================
# CONFIGURATION EMAIL (SMTP)
# ========================================
# Laisser vide pour le mode développement (affichage dans la console)
# Pour la production, configurer avec un service SMTP (Gmail, SendGrid, etc.)

# Exemple avec Gmail :
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASSWORD=votre-mot-de-passe-application
# FROM_EMAIL=noreply@centralcinema.com

# Mode développement (par défaut)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@centralcinema.com

# ========================================
# URL DU FRONTEND
# ========================================
# URL utilisée pour générer les liens de réinitialisation de mot de passe
FRONTEND_URL=http://localhost:5173
